---
interface Point {
  statement: string;
  description: string;
}

interface Group {
  heading: string;
  points: Point[];
}

interface Props {
  groups: Group[];
}

const { groups } = Astro.props;
---

<section class="beliefs">
  {
    groups.map((group) => (
      <div class="belief-group">
        <h2 class="belief-heading">{group.heading}</h2>
        <ul class="belief-points">
          {group.points.map((point) => (
            <li>
              <p class="belief-statement">{point.statement}</p>
              <p class="belief-description">{point.description}</p>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</section>

<style>
  .belief-group {
    padding: 1.75rem 0;
    border-top: 1px solid rgba(var(--ink), 0.1);
  }

  .belief-heading {
    margin: 0 0 1.25rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    text-align: center;
    color: var(--fg);
  }

  .belief-points {
    margin: 0 auto;
    padding: 0;
    list-style: none;
    max-width: 34rem;
  }

  .belief-points li {
    padding: 0.9rem 0;
    border-top: 1px solid rgba(var(--ink), 0.08);
  }

  .belief-points li:first-child {
    border-top: none;
    padding-top: 0;
  }

  .belief-points li:last-child {
    padding-bottom: 0;
  }

  .belief-statement {
    margin: 0 0 0.3rem;
    font-weight: 600;
    color: rgba(var(--ink), 0.92);
  }

  .belief-description {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: rgba(var(--ink), 0.6);
  }
</style>
