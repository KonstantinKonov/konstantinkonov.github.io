---
const links = [
  { label: "Home", href: "/" },
  { label: "projects", href: "/projects" },
  { label: "writing", href: "/writing" },
  { label: "beliefs", href: "/beliefs" },
];
---

<header class="site-header">
  <nav class="nav" aria-label="Primary">
    <ul class="nav-list">
      {
        links.map((link) => (
          <li>
            <a class="nav-link" href={link.href} data-base={link.href}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="header-actions">
    <div class="lang-switch" aria-label="Language">
      <a class="lang-link" href="/ru/" data-lang="ru">RU</a>
      <span class="lang-sep" aria-hidden="true">|</span>
      <a class="lang-link" href="/" data-lang="en">EN</a>
    </div>

    <button
      class="theme-toggle"
      type="button"
      data-theme-toggle
      aria-label="Toggle color theme"
    >
      <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9L17 7M7 17l-2.1 2.1"
        ></path>
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg);
  }

  .nav {
    display: flex;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    gap: 2.5rem;
    margin: 0;
    padding: 1.25rem 1.5rem;
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--fg);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    opacity: 1;
  }

  .header-actions {
    position: absolute;
    top: 50%;
    right: 1.5rem;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .lang-link {
    color: var(--fg);
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.15s ease;
  }

  .lang-link:hover,
  .lang-link:focus-visible {
    opacity: 0.85;
  }

  .lang-link[aria-current="true"] {
    opacity: 1;
  }

  .lang-sep {
    opacity: 0.3;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    color: var(--fg);
    background: transparent;
    border: none;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    opacity: 1;
  }

  .theme-toggle svg {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .icon-moon {
    display: none;
  }

  :global(:root[data-theme="light"]) .icon-sun {
    display: none;
  }

  :global(:root[data-theme="light"]) .icon-moon {
    display: block;
  }

  @media (max-width: 640px) {
    .nav-list {
      justify-content: flex-start;
    }

    .header-actions {
      right: 1rem;
      gap: 0.75rem;
    }
  }
</style>

<script>
  function initThemeToggle() {
    const btn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
    if (!btn || btn.dataset.ready === "true") return;
    btn.dataset.ready = "true";

    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.dataset.theme === "light" ? "dark" : "light";
      root.dataset.theme = next;
      try {
        localStorage.setItem("theme", next);
      } catch {}
    });
  }

  const NAV_LABELS: Record<string, Record<string, string>> = {
    en: { "/": "Home", "/projects": "projects", "/writing": "writing", "/beliefs": "beliefs" },
    ru: { "/": "Главная", "/projects": "проекты", "/writing": "статьи", "/beliefs": "убеждения" },
  };

  // The header is persisted across view transitions, so its locale-dependent
  // links and labels are recomputed from the current path on every navigation.
  function localizeHeader() {
    const path = document.location.pathname.replace(/\/+$/, "") || "/";
    let lang = "en";
    let base = path;
    if (path === "/ru") {
      lang = "ru";
      base = "/";
    } else if (path.startsWith("/ru/")) {
      lang = "ru";
      base = path.slice(3);
    }

    const ruHref = (b: string) => (b === "/" ? "/ru/" : "/ru" + b);
    const labels = NAV_LABELS[lang];

    document
      .querySelectorAll<HTMLAnchorElement>(".nav-link[data-base]")
      .forEach((a) => {
        const b = a.dataset.base || "/";
        a.setAttribute("href", lang === "ru" ? ruHref(b) : b);
        if (labels[b]) a.textContent = labels[b];
      });

    const en = document.querySelector<HTMLAnchorElement>('[data-lang="en"]');
    const ru = document.querySelector<HTMLAnchorElement>('[data-lang="ru"]');
    if (en) {
      en.setAttribute("href", base);
      en.setAttribute("aria-current", lang === "en" ? "true" : "false");
    }
    if (ru) {
      ru.setAttribute("href", ruHref(base));
      ru.setAttribute("aria-current", lang === "ru" ? "true" : "false");
    }
  }

  function initHeader() {
    initThemeToggle();
    localizeHeader();
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>
