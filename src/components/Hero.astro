---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="hero" id="home">
  <h1 class="hero-title">{title}</h1>
  <div class="hero-lead"><slot /></div>
</section>

<style>
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero-title {
    margin: 0 0 1.25rem;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .hero-lead :global(p) {
    max-width: 42rem;
    margin: 0;
    font-size: 1.0625rem;
    color: rgba(var(--ink), 0.72);
  }
</style>
