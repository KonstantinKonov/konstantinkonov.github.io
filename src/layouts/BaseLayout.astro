---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import Header from "../components/Header.astro";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>konstantin.konov</title>
    <script is:inline>
      // Applied before paint on full loads, and again after every client-side
      // transition (the swap resets html[data-theme] to the fetched page's
      // markup, which never has it baked in — see astro:after-swap below).
      function applyStoredTheme() {
        try {
          var t = localStorage.getItem("theme");
          if (t === "light" || t === "dark") {
            document.documentElement.dataset.theme = t;
          }
        } catch (e) {}
      }
      applyStoredTheme();
      document.addEventListener("astro:after-swap", applyStoredTheme);
    </script>
    <ViewTransitions />
  </head>
  <body>
    <Header transition:persist />
    <main class="site-main">
      <slot />
    </main>

    <style>
      .site-main {
        padding-top: 4.5rem;
      }
    </style>
  </body>
</html>
